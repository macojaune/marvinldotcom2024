---
import Link from "./Link.astro"
import SocialShare from "./socialShare/SocialShare.astro"

interface Props {
  backHref: string
  backLabel: string
  description?: string
  eyebrow: string
  meta?: string[]
  shareDescription?: string
  shareTitle: string
  title: string
}

const {
  backHref,
  backLabel,
  description,
  eyebrow,
  meta = [],
  shareDescription,
  shareTitle,
  title
} = Astro.props
---

<header class='grid gap-10 py-8 md:gap-12 md:py-12'>
  <div class='flex flex-wrap items-center justify-between gap-4 md:gap-6'>
    <Link url={backHref} target='_self' variant='subtle'>
      {backLabel}
    </Link>
    <SocialShare
      description={shareDescription ?? description ?? title}
      title={shareTitle}
    />
  </div>

  <div class='grid gap-6'>
    <p
      class='font-mono text-[0.68rem] uppercase tracking-[0.3em] text-l/tertiary dark:text-d/accent'
    >
      {eyebrow}
    </p>
    <h1
      class='max-w-5xl font-display text-5xl leading-[0.88] tracking-[-0.05em] text-l/primary dark:text-d/primary md:text-7xl xl:text-[6.2rem]'
    >
      {title}
    </h1>
    {
      description && (
        <p class='max-w-3xl text-base leading-8 text-l/secondary dark:text-d/muted md:text-[1.22rem]'>
          {description}
        </p>
      )
    }
    {
      meta.length > 0 && (
        <div class='flex flex-wrap gap-x-4 gap-y-2'>
          {meta.map((item) => (
            <span class='font-mono text-[0.68rem] uppercase tracking-[0.24em] text-l/secondary dark:text-d/subtle'>
              {item}
            </span>
          ))}
        </div>
      )
    }
  </div>
</header>
