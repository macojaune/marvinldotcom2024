---
import { getCollection } from "astro:content"
import EditorialHeader from "../../components/EditorialHeader.astro"
import EditorialProse from "../../components/EditorialProse.astro"
import ContentFooter from "../../components/ContentFooter.astro"
import Layout from "@/layouts/Layout.astro"
// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const projectEntries = await getCollection("project", ({ data }) => {
    return import.meta.env.PROD ? data.isDraft !== true : true
  })
  return projectEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }))
}
// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props
const { Content } = await entry.render()
const formattedCreatedAt = new Date(entry.data.createdAt).toLocaleDateString(
  "fr-FR",
  {
    day: "numeric",
    month: "long",
    year: "numeric"
  }
)
const formattedUpdatedAt = new Date(entry.data.updatedAt).toLocaleDateString(
  "fr-FR",
  {
    day: "numeric",
    month: "long",
    year: "numeric"
  }
)
const description = `Découvre ${entry.data.title}, un projet web conçu par MarvinL.com. Explore son contexte, ses choix techniques et la manière dont l'idée a pris forme en ligne.`
const json = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `${entry.data.title} − Un projet MarvinL.com`,
  image: "",
  author: {
    "@type": "",
    name: "MarvinL.com"
  },
  publisher: {
    "@type": "Organization",
    name: "MarvinL.com"
  },
  datePublished: new Date(entry.data.createdAt).toLocaleDateString(),
  dateModified: new Date(entry.data.updatedAt).toLocaleDateString()
}
---

<Layout
  wide
  title={entry.data.title + " − Un projet MarvinL.com"}
  desc={description}
>
  <script
    is:inline
    type='application/ld+json'
    set:html={JSON.stringify(json)}
  />

  <EditorialHeader
    backHref='/projets'
    backLabel='Retour aux projets'
    eyebrow='Projet'
    title={entry.data.title}
    description={entry.data.description}
    meta={[
      entry.data.isClient ? "Projet client" : "Projet personnel",
      `Publié le ${formattedCreatedAt}`,
      `Mis à jour le ${formattedUpdatedAt}`
    ]}
    shareDescription={`Découvre ${entry.data.title}, le dernier projet conçu par MarvinL.com. Développeur web en freelance depuis la Guadeloupe.`}
    shareTitle={entry.data.title + " − Un projet MarvinL.com"}
  />

  <EditorialProse>
    <Content />
  </EditorialProse>

  <section class='grid max-w-[46rem] gap-4 py-8'>
    <p
      class='font-mono text-[0.68rem] uppercase tracking-[0.3em] text-l/tertiary dark:text-d/accent'
    >
      Technologies utilisées
    </p>
    <ul class='flex flex-wrap gap-x-4 gap-y-2'>
      {
        entry.data.technos.map((tech: string) => (
          <li class='font-mono text-[0.72rem] uppercase tracking-[0.22em] text-l/secondary dark:text-d/subtle'>
            {tech}
          </li>
        ))
      }
    </ul>
  </section>
  <ContentFooter />
</Layout>
