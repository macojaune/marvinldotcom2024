---
import { getCollection } from "astro:content"
import EditorialHeader from "../../components/EditorialHeader.astro"
import EditorialProse from "../../components/EditorialProse.astro"
import Layout from "@/layouts/Layout.astro"
// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? data.isDraft !== true : true
  })
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }))
}
// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props
const { Content } = await entry.render()
const formattedCreatedAt = new Date(entry.data.createdAt).toLocaleDateString(
  "fr-FR",
  {
    day: "numeric",
    month: "long",
    year: "numeric"
  }
)
const formattedUpdatedAt = new Date(entry.data.updatedAt).toLocaleDateString(
  "fr-FR",
  {
    day: "numeric",
    month: "long",
    year: "numeric"
  }
)
const json = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `${entry.data.title} − Un article MarvinL.com`,
  image: "",
  author: {
    "@type": "",
    name: "MarvinL.com"
  },
  publisher: {
    "@type": "Organization",
    name: "MarvinL.com"
  },
  datePublished: new Date(entry.data.createdAt).toLocaleDateString(),
  dateModified: new Date(entry.data.updatedAt).toLocaleDateString()
}
---

<Layout wide title={entry.data.title} desc={entry.data.description}>
  <script type='application/ld+json' set:html={JSON.stringify(json)} />

  <EditorialHeader
    backHref='/blog'
    backLabel='Retour au blog'
    eyebrow='Article'
    title={entry.data.title}
    description={entry.data.description}
    meta={[
      `Publié le ${formattedCreatedAt}`,
      `Mis à jour le ${formattedUpdatedAt}`
    ]}
    shareDescription={entry.data.description}
    shareTitle={`Je viens de lire "${entry.data.title}" sur le blog MarvinL.com`}
  />

  <EditorialProse>
    <Content />
  </EditorialProse>
</Layout>
