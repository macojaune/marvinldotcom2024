---
import { getCollection } from "astro:content"
import EditorialHeader from "../../components/EditorialHeader.astro"
import EditorialProse from "../../components/EditorialProse.astro"
import Layout from "@/layouts/Layout.astro"
import { buildBreadcrumbList, getCanonicalUrl } from "../../seo"
// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? data.isDraft !== true : true
  })
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }))
}
// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props
const { Content } = await entry.render()
const formattedCreatedAt = new Date(entry.data.createdAt).toLocaleDateString(
  "fr-FR",
  {
    day: "numeric",
    month: "long",
    year: "numeric"
  }
)
const formattedUpdatedAt = new Date(entry.data.updatedAt).toLocaleDateString(
  "fr-FR",
  {
    day: "numeric",
    month: "long",
    year: "numeric"
  }
)
const description =
  entry.data.description ??
  `Article de MarvinL.com sur le développement web, le freelance et les projets web depuis la Guadeloupe.`
const canonical = getCanonicalUrl(`/blog/${entry.slug}/`)
const json = {
  "@type": "BlogPosting",
  "@id": `${canonical}#article`,
  headline: `${entry.data.title} − Un article MarvinL.com`,
  url: canonical,
  description,
  author: {
    "@id": "https://www.marvinl.com/#person"
  },
  publisher: {
    "@id": "https://www.marvinl.com/#service"
  },
  mainEntityOfPage: canonical,
  inLanguage: "fr-FR",
  datePublished: new Date(entry.data.createdAt).toISOString(),
  dateModified: new Date(entry.data.updatedAt).toISOString()
}
const breadcrumb = buildBreadcrumbList([
  { name: "Accueil", url: "/" },
  { name: "Blog", url: "/blog/" },
  { name: entry.data.title, url: `/blog/${entry.slug}/` }
])
---

<Layout
  wide
  title={entry.data.title}
  desc={description}
  canonical={canonical}
  ogType='article'
  publishedTime={entry.data.createdAt}
  modifiedTime={entry.data.updatedAt}
  structuredData={[json, breadcrumb]}
>
  <EditorialHeader
    backHref='/blog'
    backLabel='Retour au blog'
    eyebrow='Article'
    title={entry.data.title}
    description={description}
    meta={[
      `Publié le ${formattedCreatedAt}`,
      `Mis à jour le ${formattedUpdatedAt}`
    ]}
    shareDescription={description}
    shareTitle={`Je viens de lire "${entry.data.title}" sur le blog MarvinL.com`}
  />

  <EditorialProse>
    <Content />
  </EditorialProse>
</Layout>
